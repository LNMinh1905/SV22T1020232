@model Product
@{
    ViewBag.Title = Model.ProductID == 0 ? "Bổ sung mặt hàng" : "Cập nhật thông tin mặt hàng";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-action="Save">
                    <input type="hidden" asp-for="ProductID" />
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input asp-for="ProductName"
                                   class="form-control"
                                   placeholder="Nhập tên mặt hàng" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select asp-for="CategoryID" class="form-select" asp-items="await SelectListHelper.Categories()">
                            </select>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select asp-for="SupplierID" class="form-select" asp-items="await SelectListHelper.Suppliers()">
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input asp-for="Unit"
                                   class="form-control"
                                   placeholder="cái, hộp, kg..." />
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input asp-for="Price"
                                   class="form-control"
                                   placeholder="Giá bán" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       asp-for="IsSelling" />
                                <label class="form-check-label" asp-for="IsSelling">
                                    Đang bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh (tên file)</label>
                        <div class="col-sm-9">
                            <input asp-for="Photo"
                                   class="form-control"
                                   placeholder="nophoto.png" />
                            <small class="text-muted">Để trống sẽ mặc định là nophoto.png</small>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea asp-for="ProductDescription"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Nhập mô tả mặt hàng"></textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.ProductID > 0)
        {
            <div class="card card-secondary card-outline mt-3">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-images me-2"></i>
                        Ảnh sản phẩm
                    </h5>
                </div>
                <div class="card-body">
                    <a href="~/Product/ListPhotos/@Model.ProductID" class="btn btn-sm btn-info">
                        <i class="bi bi-images"></i> Quản lý ảnh
                    </a>
                </div>
            </div>

            <div class="card card-secondary card-outline mt-3">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-list-ul me-2"></i>
                        Thuộc tính sản phẩm
                    </h5>
                </div>
                <div class="card-body">
                    <a href="~/Product/ListAttributes/@Model.ProductID" class="btn btn-sm btn-info">
                        <i class="bi bi-list-ul"></i> Quản lý thuộc tính
                    </a>
                </div>
            </div>
        }
    </div>
</div>
