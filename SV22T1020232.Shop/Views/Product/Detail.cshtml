@model Product
@{
    ViewData["Title"] = Model.ProductName;
    var photos = ViewBag.Photos as List<ProductPhoto>;
    var attributes = ViewBag.Attributes as List<ProductAttribute>;
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Product Images -->
        <div class="col-lg-5 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <!-- Main Image -->
                    <div id="productMainImage" class="text-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.Photo))
                        {
                            <img src="~/images/products/@Model.Photo" alt="@Model.ProductName" 
                                 class="img-fluid rounded" style="max-height: 400px; object-fit: contain;">
                        }
                        else
                        {
                            <img src="~/images/products/nophoto.png" alt="No Photo" 
                                 class="img-fluid rounded" style="max-height: 400px; object-fit: contain;">
                        }
                    </div>

                    <!-- Photo Gallery -->
                    @if (photos != null && photos.Count > 0)
                    {
                        <div class="row g-2">
                            @foreach (var photo in photos)
                            {
                                <div class="col-3">
                                    <img src="~/images/products/@photo.Photo" alt="@photo.DisplayOrder" 
                                         class="img-thumbnail cursor-pointer" 
                                         style="height: 80px; object-fit: cover; cursor: pointer;"
                                         onclick="changeMainImage('~/images/products/@photo.Photo')">
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <!-- Category Badge -->
                    <div class="mb-2">
                        <span class="badge bg-secondary">
                            <i class="bi bi-tag"></i> Loại hàng: @Model.CategoryID
                        </span>
                    </div>

                    <!-- Product Name -->
                    <h2 class="mb-3">@Model.ProductName</h2>

                    <!-- Price -->
                    <div class="mb-3">
                        <h3 class="text-danger fw-bold">
                            @Model.Price.ToString("N0") đ
                        </h3>
                        <p class="text-muted">
                            <i class="bi bi-box"></i> Đơn vị: <strong>@Model.Unit</strong>
                        </p>
                    </div>

                    <!-- Supplier -->
                    <div class="mb-3">
                        <p class="mb-1">
                            <i class="bi bi-building"></i> Nhà cung cấp: <strong>@Model.SupplierID</strong>
                        </p>
                    </div>

                    <hr>

                    <!-- Add to Cart Form -->
                    <div class="mb-4">
                        <form id="addToCartForm">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Số lượng:</label>
                                    <input type="number" id="quantity" class="form-control" value="1" min="1" max="999">
                                </div>
                                <div class="col-md-8">
                                    <button type="button" class="btn btn-primary btn-lg w-100" onclick="addToCart(@Model.ProductID)">
                                        <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>

                    <hr>

                    <!-- Description -->
                    @if (!string.IsNullOrEmpty(Model.ProductDescription))
                    {
                        <div class="mb-3">
                            <h5><i class="bi bi-info-circle"></i> Mô tả sản phẩm</h5>
                            <p class="text-muted">@Model.ProductDescription</p>
                        </div>
                    }

                    <!-- Attributes -->
                    @if (attributes != null && attributes.Count > 0)
                    {
                        <div class="mb-3">
                            <h5><i class="bi bi-list-check"></i> Thuộc tính sản phẩm</h5>
                            <table class="table table-bordered table-sm">
                                <tbody>
                                    @foreach (var attr in attributes)
                                    {
                                        <tr>
                                            <td class="fw-bold" style="width: 40%;">@attr.AttributeName</td>
                                            <td>@attr.AttributeValue</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Back Button -->
            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(imageSrc) {
            const mainImage = document.querySelector('#productMainImage img');
            mainImage.src = imageSrc;
        }

        function addToCart(productId) {
            const quantity = document.getElementById('quantity').value;
            
            // TODO: Implement add to cart functionality (Prompt 5.1)
            alert(`Thêm ${quantity} sản phẩm vào giỏ hàng.\nChức năng này sẽ được triển khai ở Prompt 5.1`);
        }
    </script>
}
