@using SV22T1020232.Models.Sales
@model SV22T1020232.Models.Sales.OrderViewInfo
@{
    ViewData["Title"] = $"Đơn Hàng #{Model.OrderID}";
    var orderDetails = ViewBag.OrderDetails as List<OrderDetailViewInfo>;
    decimal totalAmount = Convert.ToDecimal(ViewBag.TotalAmount ?? 0);
    bool canCancel = Model.Status == OrderStatusEnum.New;

    var steps = new[]
    {
        new { Status = OrderStatusEnum.New,       Icon = "bi-bag-plus",      Label = "Đã đặt",    Time = (DateTime?)Model.OrderTime },
        new { Status = OrderStatusEnum.Accepted,  Icon = "bi-shield-check",   Label = "Xác nhận",  Time = Model.AcceptTime },
        new { Status = OrderStatusEnum.Shipping,  Icon = "bi-truck",          Label = "Đang giao", Time = Model.ShippedTime },
        new { Status = OrderStatusEnum.Completed, Icon = "bi-box-seam-fill",  Label = "Nhận hàng", Time = Model.FinishedTime }
    };

    int currentStep = Model.Status switch
    {
        OrderStatusEnum.New => 0,
        OrderStatusEnum.Accepted => 1,
        OrderStatusEnum.Shipping => 2,
        OrderStatusEnum.Completed => 3,
        _ => -1
    };

    var statusTheme = Model.Status switch
    {
        OrderStatusEnum.New => new { Bg = "#EEF2FF", Text = "#4F46E5", Label = "Chờ duyệt" },
        OrderStatusEnum.Accepted => new { Bg = "#ECFDF5", Text = "#059669", Label = "Đã xác nhận" },
        OrderStatusEnum.Shipping => new { Bg = "#FFFBEB", Text = "#D97706", Label = "Đang vận chuyển" },
        OrderStatusEnum.Completed => new { Bg = "#F0FDF4", Text = "#16A34A", Label = "Hoàn tất" },
        _ => new { Bg = "#FEF2F2", Text = "#DC2626", Label = "Đã hủy" }
    };
}

<style>
    :root {
        --primary-2026: #4F46E5;
        --surface-2026: #ffffff;
        --bg-2026: #f8fafc;
    }

    body {
        background-color: var(--bg-2026);
    }

    .bento-card {
        background: var(--surface-2026);
        border: 1px solid rgba(226, 232, 240, 0.6);
        border-radius: 24px;
        padding: 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        transition: transform 0.3s ease;
    }

    /* Status Bar */
    .status-pill {
        background: @statusTheme.Bg;
        color: @statusTheme.Text;
        padding: 8px 16px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    /* Modern Timeline */
    .timeline-2026 {
        display: flex;
        justify-content: space-between;
        position: relative;
        padding: 2rem 0;
    }

        .timeline-2026::before {
            content: "";
            position: absolute;
            top: 50%;
            left: 5%;
            right: 5%;
            height: 2px;
            background: #e2e8f0;
            transform: translateY(-24px);
            z-index: 1;
        }

    .timeline-progress-2026 {
        position: absolute;
        top: 50%;
        left: 5%;
        height: 2px;
        background: var(--primary-2026);
        transform: translateY(-24px);
        z-index: 2;
        transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .t-step {
        position: relative;
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100px;
    }

    .t-icon {
        width: 48px;
        height: 48px;
        background: #fff;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #94a3b8;
        margin-bottom: 12px;
        transition: 0.4s;
    }

    .t-step.active .t-icon {
        background: var(--primary-2026);
        color: #fff;
        border-color: var(--primary-2026);
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.3);
    }

    .t-step.done .t-icon {
        border-color: var(--primary-2026);
        color: var(--primary-2026);
    }

    /* Product Item */
    .product-micro-card {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        padding: 1rem;
        border-radius: 18px;
        border-bottom: 1px solid #f1f5f9;
    }

        .product-micro-card:last-child {
            border-bottom: none;
        }

    .product-img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 14px;
        background: #f1f5f9;
    }

    /* Action Buttons */
    .btn-action-2026 {
        padding: 12px 24px;
        border-radius: 14px;
        font-weight: 600;
        transition: 0.3s;
    }
</style>

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <a asp-action="MyOrders" class="text-decoration-none text-muted small fw-bold mb-2 d-block">
                <i class="bi bi-chevron-left"></i> QUAY LẠI DANH SÁCH
            </a>
            <h3 class="fw-800 text-dark mb-0">Đơn hàng #@Model.OrderID</h3>
        </div>
        <div class="d-flex gap-2">
            @if (canCancel)
            {
                <button id="btnCancelOrder" class="btn btn-action-2026 btn-outline-danger">Hủy đơn</button>
            }
            <div class="status-pill">
                <i class="bi bi-dot fs-4"></i> @statusTheme.Label
            </div>
        </div>
    </div>

    @if (Model.Status != OrderStatusEnum.Cancelled && Model.Status != OrderStatusEnum.Rejected)
    {
        <div class="bento-card mb-4 overflow-hidden">
            <div class="timeline-2026">
                <div class="timeline-progress-2026" style="width: @(currentStep * 30)%"></div>
                @for (int i = 0; i < steps.Length; i++)
                {
                    var s = steps[i];
                    <div class="t-step @(currentStep >= i ? "done" : "") @(currentStep == i ? "active" : "")">
                        <div class="t-icon"><i class="bi @s.Icon"></i></div>
                        <span class="small fw-bold @(currentStep >= i ? "text-dark" : "text-muted")">@s.Label</span>
                        <span class="text-muted" style="font-size: 0.65rem;">@s.Time?.ToString("dd/MM HH:mm")</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="bento-card h-100">
                <h6 class="fw-800 text-uppercase mb-4" style="letter-spacing: 1px; font-size: 0.8rem;">
                    <i class="bi bi-box-seam me-2"></i> Sản phẩm đơn hàng
                </h6>
                <div class="product-list">
                    @if (orderDetails != null)
                    {
                        foreach (var d in orderDetails)
                        {
                            <div class="product-micro-card">
                                <img src="/images/products/@(string.IsNullOrEmpty(d.Photo) ? "nophoto.png" : d.Photo)"
                                     class="product-img shadow-sm" onerror="this.src='/images/products/nophoto.png'">
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold">@d.ProductName</h6>
                                    <span class="text-muted small">@d.Unit | SL: @d.Quantity</span>
                                </div>
                                <div class="text-end">
                                    <div class="fw-800">@d.TotalPrice.ToString("N0") ₫</div>
                                    <div class="text-muted small">@d.SalePrice.ToString("N0") ₫</div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="d-flex flex-column gap-4">
                <div class="bento-card">
                    <h6 class="fw-800 text-uppercase mb-3 small"><i class="bi bi-person me-2"></i> Người nhận</h6>
                    <div class="fw-bold text-dark">@Model.CustomerName</div>
                    <div class="small text-muted mt-1">@Model.CustomerPhone</div>
                    <div class="small text-muted mt-2">@Model.DeliveryAddress, @Model.DeliveryProvince</div>
                </div>

                <div class="bento-card" style="background: #1e293b; color: #fff;">
                    <h6 class="text-uppercase mb-3 small opacity-50 fw-800 text-white">Thanh toán đơn hàng</h6>
                    <div class="d-flex justify-content-between mb-2 opacity-75 small">
                        <span>Giá tạm tính</span>
                        <span>@totalAmount.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 opacity-75 small">
                        <span>Vận chuyển</span>
                        <span class="text-success fw-bold">Free</span>
                    </div>
                    <hr class="opacity-10">
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="fw-bold">TỔNG CỘNG</span>
                        <h4 class="fw-800 mb-0 text-white">@totalAmount.ToString("N0") ₫</h4>
                    </div>
                    <div class="mt-4">
                        <span class="badge w-100 py-2" style="background: rgba(255,255,255,0.1);">
                            THANH TOÁN COD
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hiệu ứng mượt mà khi load timeline
        document.addEventListener('DOMContentLoaded', () => {
            const progress = document.querySelector('.timeline-progress-2026');
            if(progress) {
                const currentWidth = progress.style.width;
                progress.style.width = '0%';
                setTimeout(() => { progress.style.width = currentWidth; }, 300);
            }
        });

        @if (canCancel)
        {
                <text>
                document.getElementById('btnCancelOrder')?.addEventListener('click', () => {
                    if(confirm('Bạn có chắc chắn muốn hủy đơn hàng này?')) {
                        // Fetch logic giữ nguyên
                    }
                });
                </text>
        }
    </script>
}