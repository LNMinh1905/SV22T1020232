@model OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">
        Hủy đơn hàng #@Model.OrderID
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form id="formOrderCancel" method="post" action="@Url.Action("Cancel", "Order", new { id = Model.OrderID })" onsubmit="return handleOrderCancel(event, this);">
    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có chắc chắn muốn hủy đơn hàng này?
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-check"></i> Hủy đơn
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>
<script>
    function handleOrderCancel(event, form) {
        event.preventDefault();

        const formData = new FormData(form);

        fetch(form.action, {
            method: 'POST',
            body: formData
        })
        .then(response => {
            if (!response.ok) {
                throw new Error('Lỗi khi gọi API');
            }
            return response.json();
        })
        .then(result => {
            if (result.Code === 0) {
                alert(result.Message);
            } else {
                const modalElement = document.getElementById('dialogModal');
                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                if (modalInstance) {
                    modalInstance.hide();
                }
                alert(result.Message || 'Hủy đơn hàng thành công!');
                window.location.reload();
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Không gửi được yêu cầu');
        });

        return false;
    }
</script>
