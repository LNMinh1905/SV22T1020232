@using SV22T1020232.Admin
@using SV22T1020232.Admin.Models
@using SV22T1020232.Models.Catalog
@using SV22T1020232.Models.Common
@using SV22T1020232.Models.DataDictionary
@using SV22T1020232.Models.HR
@using SV22T1020232.Models.Partner
@using SV22T1020232.Models.Sales
@using SV22T1020232.Models.Security
@model Shipper

@{
    ViewBag.Title = "Xóa người giao hàng";
}

@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i>
        Xóa
    </button>

    <a asp-controller="Shipper"
       asp-action="Index"
       class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa người giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" method="post" asp-action="ConfirmDelete">
                    <input type="hidden" asp-for="ShipperID" />

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa người giao hàng sau không?
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Tên người giao hàng</dt>
                        <dd class="col-sm-8">@Model.ShipperName</dd>

                        <dt class="col-sm-4">Điện thoại</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>
                    </dl>

                </form>
            </div>
        </div>
    </div>
</div>
