@model SV22T1020232.Shop.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký thành viên";
}

<style>
    /* NÂNG CẤP GIAO DIỆN REGISTER */
    .auth-wrapper {
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 0;
    }

    .auth-card {
        background: #fff;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        overflow: hidden;
        max-width: 950px;
        width: 100%;
    }

    .auth-banner {
        background: #0f172a; /* Tông màu tối hiện đại */
        position: relative;
        overflow: hidden;
        padding: 3rem;
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        /* Hiệu ứng Glow mờ phía sau */
        .auth-banner::after {
            content: "";
            position: absolute;
            bottom: -10%;
            left: -10%;
            width: 250px;
            height: 250px;
            background: var(--primary);
            filter: blur(90px);
            border-radius: 50%;
            opacity: 0.15;
        }

    .form-control-modern {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 0.95rem;
        transition: all 0.2s;
        background-color: #f8fafc;
        width: 100%;
    }

        .form-control-modern:focus {
            background-color: #fff;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            outline: none;
        }

    .label-custom {
        font-size: 0.85rem;
        font-weight: 600;
        color: #475569;
        margin-bottom: 0.5rem;
        display: block;
    }

    .btn-register {
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

        .btn-register:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.2);
        }

    .toggle-password {
        cursor: pointer;
        color: #94a3b8;
        z-index: 10;
    }

    .term-text {
        font-size: 0.8rem;
        line-height: 1.5;
        color: #64748b;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="row g-0">
            <div class="col-md-5 auth-banner d-none d-md-flex">
                <div class="position-relative" style="z-index: 2;">
                    <div class="mb-5">
                        <span class="fs-4 fw-bold">LNM<span style="color: var(--primary);">.</span>SHOP</span>
                    </div>

                    <div class="mb-4">
                        <div class="rounded-3 bg-white bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="bi bi-person-plus text-primary fs-3"></i>
                        </div>
                        <h2 class="fw-bold mb-3">Trở thành thành viên</h2>
                        <p class="text-muted-foreground" style="color: #94a3b8;">Đăng ký ngay để nhận ưu đãi giảm giá lên đến 20% cho đơn hàng đầu tiên và tích điểm thưởng.</p>
                    </div>

                    <div class="mt-5 border-top border-white border-opacity-10 pt-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <i class="bi bi-check2-circle text-primary"></i>
                            <span class="small text-white-50">Cập nhật xu hướng mới nhất</span>
                        </div>
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <i class="bi bi-check2-circle text-primary"></i>
                            <span class="small text-white-50">Hỗ trợ khách hàng 24/7</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7 p-4 p-lg-5 bg-white">
                <div class="mb-4">
                    <h3 class="fw-bold text-dark mb-1">Tạo tài khoản mới</h3>
                    <p class="text-muted small">Vui lòng điền các thông tin dưới đây để bắt đầu.</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small rounded-3"></div>

                    <div class="mb-3">
                        <label asp-for="CustomerName" class="label-custom">Tên đầy đủ của bạn</label>
                        <input asp-for="CustomerName" class="form-control-modern" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="CustomerName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="label-custom">Địa chỉ Email</label>
                        <input asp-for="Email" class="form-control-modern" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Password" class="label-custom">Mật khẩu</label>
                            <div class="position-relative">
                                <input asp-for="Password" id="regPassword" type="password"
                                       class="form-control-modern" placeholder="••••••••" style="padding-right: 40px;" />
                                <span class="position-absolute end-0 top-50 translate-middle-y me-3 toggle-password"
                                      onclick="togglePassword('regPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="label-custom">Xác nhận lại</label>
                            <div class="position-relative">
                                <input asp-for="ConfirmPassword" id="regConfirmPassword" type="password"
                                       class="form-control-modern" placeholder="••••••••" style="padding-right: 40px;" />
                                <span class="position-absolute end-0 top-50 translate-middle-y me-3 toggle-password"
                                      onclick="togglePassword('regConfirmPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="term-text mb-4">
                        Bằng việc nhấn "Đăng ký", bạn đồng ý với <a href="#" class="text-primary text-decoration-none fw-semibold">Điều khoản dịch vụ</a> và <a href="#" class="text-primary text-decoration-none fw-semibold">Chính sách bảo mật</a> của LNM Shop.
                    </div>

                    <button type="submit" class="btn-register w-100 mb-4">
                        Đăng ký ngay
                    </button>

                    <div class="text-center pt-2">
                        <span class="text-muted small">Đã có tài khoản?</span>
                        <a asp-action="Login" class="small fw-bold text-decoration-none ms-1" style="color: var(--primary);">Đăng nhập tại đây</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}