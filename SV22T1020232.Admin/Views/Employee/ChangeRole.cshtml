@model Employee
@{
    ViewBag.Title = "Phân quyền nhân viên";
}
@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock me-2"></i>
                    Phân quyền cho nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangeRole" method="post" asp-action="SaveRole">
                    <input type="hidden" name="id" value="@Model.EmployeeID" />

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-list-check me-1"></i>
                            Danh sách quyền (demo)
                        </legend>

                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="roles" value="Administrator" id="roleAdmin">
                            <label class="form-check-label" for="roleAdmin">
                                Quản trị hệ thống
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="roles" value="Sales" id="roleSales">
                            <label class="form-check-label" for="roleSales">
                                Nhân viên bán hàng
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="roles" value="Warehouse" id="roleWarehouse">
                            <label class="form-check-label" for="roleWarehouse">
                                Nhân viên kho
                            </label>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>