@{
    ViewBag.Title = "Tài khoản";
}
<div class="card">
    <div class="card-body">
        <h5>Thông tin đăng nhập hiện tại</h5>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <p><strong>Tên đăng nhập:</strong> @User.Identity.Name</p>
            <p><strong>Tên hiển thị:</strong> @User.FindFirst("DisplayName")?.Value</p>
            <p><strong>Email:</strong> @User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>

            <form asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-box-arrow-right me-1"></i>
                    Đăng xuất
                </button>
                <a href="~/Account/ChangePassword" class="btn btn-secondary ms-1">
                    <i class="bi bi-key me-1"></i>
                    Đổi mật khẩu
                </a>
            </form>
        }
        else
        {
            <p>Bạn chưa đăng nhập. <a href="~/Account/Login">Đăng nhập</a></p>
        }
    </div>
</div>