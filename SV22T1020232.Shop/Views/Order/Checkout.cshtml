@model SV22T1020232.Shop.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Xác Nhận Đặt Hàng";
    var cart = ViewBag.Cart as List<SV22T1020232.Shop.CartItem>;
    decimal total = Convert.ToDecimal(ViewBag.TotalAmount ?? 0);
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        --glass-bg: rgba(255, 255, 255, 0.85);
        --card-shadow: 0 8px 32px rgba(31, 38, 135, 0.05);
    }

    body {
        background-color: #f4f7ff;
    }

    /* ── Tóm tắt trạng thái (Timeline) ── */
    .checkout-header {
        text-align: center;
        padding: 2rem 0;
    }

    .timeline-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0;
        margin-top: 1.5rem;
    }

    .t-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 1;
        width: 120px;
    }

    .t-dot {
        width: 32px;
        height: 32px;
        background: #fff;
        border: 2px solid #e2e8f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        transition: 0.3s;
        margin-bottom: 8px;
    }

    .t-step.active .t-dot {
        background: var(--primary-gradient);
        border-color: transparent;
        color: white;
        box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
    }

    .t-line {
        height: 2px;
        width: 80px;
        background: #e2e8f0;
        margin-top: -30px;
    }

        .t-line.active {
            background: #6366f1;
        }

    /* ── Form & Cards ── */
    .bento-card {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 24px;
        padding: 2rem;
        box-shadow: var(--card-shadow);
        margin-bottom: 1.5rem;
    }

    .form-floating > .form-control-modern {
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        background: #fff;
        padding: 1rem 1rem;
        height: 60px;
    }

    .form-control-modern:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }

    /* ── Order Summary Sidebar ── */
    .order-summary-box {
        position: sticky;
        top: 2rem;
        border-radius: 24px;
        background: #1e293b;
        color: #fff;
        padding: 2rem;
    }

    .product-row {
        background: rgba(255,255,255,0.05);
        border-radius: 16px;
        padding: 12px;
        margin-bottom: 10px;
        transition: 0.3s;
    }

        .product-row:hover {
            background: rgba(255,255,255,0.1);
        }

    .total-highlight {
        background: var(--primary-gradient);
        border-radius: 16px;
        padding: 1.5rem;
        margin-top: 1rem;
    }

    .btn-confirm {
        background: #fff;
        color: #1e293b;
        border: none;
        border-radius: 14px;
        padding: 1.2rem;
        width: 100%;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }

        .btn-confirm:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            background: #f8fafc;
        }

    /* ── Payment Option ── */
    .payment-option {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 1.2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        cursor: pointer;
        transition: 0.3s;
    }

        .payment-option.selected {
            border-color: #6366f1;
            background: rgba(99, 102, 241, 0.05);
        }
</style>

<div class="container pb-5">
    <header class="checkout-header">
        <h2 class="fw-800">Thanh toán đơn hàng</h2>
        <div class="timeline-container">
            <div class="t-step"><div class="t-dot"><i class="bi bi-cart"></i></div><span class="small text-muted">Giỏ hàng</span></div>
            <div class="t-line active"></div>
            <div class="t-step active"><div class="t-dot">2</div><span class="small fw-bold">Thông tin</span></div>
            <div class="t-line"></div>
            <div class="t-step"><div class="t-dot">3</div><span class="small text-muted">Hoàn tất</span></div>
        </div>
    </header>

    <div class="row g-4">
        <div class="col-lg-8">
            <form asp-action="Checkout" method="post" id="checkoutForm">
                <div class="bento-card">
                    <h5 class="fw-bold mb-4 d-flex align-items-center">
                        <i class="bi bi-geo-alt-fill text-primary me-2"></i> Thông tin nhận hàng
                    </h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control form-control-modern" value="@Model.CustomerName" readonly style="background-color: #f1f5f9;">
                                <label class="text-muted">Họ và tên</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control form-control-modern" value="@Model.Phone" readonly style="background-color: #f1f5f9;">
                                <label class="text-muted">Số điện thoại</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating mb-3">
                                <input asp-for="DeliveryProvince" class="form-control form-control-modern" placeholder="Tỉnh/Thành">
                                <label asp-for="DeliveryProvince">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                                <span asp-validation-for="DeliveryProvince" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating mb-3">
                                <textarea asp-for="DeliveryAddress" class="form-control form-control-modern" style="height: 100px" placeholder="Địa chỉ"></textarea>
                                <label asp-for="DeliveryAddress">Địa chỉ chi tiết (Số nhà, đường...)</label>
                                <span asp-validation-for="DeliveryAddress" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Note" class="form-control form-control-modern" placeholder="Ghi chú">
                                <label asp-for="Note">Ghi chú thêm cho đơn hàng</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bento-card">
                    <h5 class="fw-bold mb-4 d-flex align-items-center">
                        <i class="bi bi-credit-card-fill text-primary me-2"></i> Phương thức thanh toán
                    </h5>
                    <div class="payment-option selected">
                        <div class="icon-circle bg-primary text-white p-2 rounded-circle">
                            <i class="bi bi-truck px-1"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-bold">Thanh toán khi nhận hàng (COD)</div>
                            <div class="small text-muted">Nhận hàng rồi mới trả tiền. An toàn 100%</div>
                        </div>
                        <i class="bi bi-check-circle-fill text-primary fs-4"></i>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-4">
            <div class="order-summary-box shadow-lg">
                <h5 class="fw-bold mb-4 border-bottom border-secondary pb-3">Chi tiết đơn hàng</h5>

                <div class="order-items-scroll mb-4" style="max-height: 250px;">
                    @if (cart != null)
                    {
                        @foreach (var item in cart)
                        {
                            <div class="product-row d-flex align-items-center gap-3">
                                <img src="/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                     class="rounded-3" style="width: 50px; height: 50px; object-fit: cover;">
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="small fw-bold text-truncate">@item.ProductName</div>
                                    <div class="text-secondary" style="font-size: 0.75rem;">SL: @item.Quantity</div>
                                </div>
                                <div class="small fw-bold">@item.Amount.ToString("N0") ₫</div>
                            </div>
                        }
                    }
                </div>

                <div class="d-flex justify-content-between mb-2 small">
                    <span class="text-secondary">Tạm tính</span>
                    <span>@total.ToString("N0") ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-3 small">
                    <span class="text-secondary">Phí vận chuyển</span>
                    <span class="text-success fw-bold">Free</span>
                </div>

                <div class="total-highlight">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold">TỔNG CỘNG</span>
                        <h3 class="fw-800 mb-0">@total.ToString("N0") ₫</h3>
                    </div>
                </div>

                <button type="submit" form="checkoutForm" class="btn-confirm mt-4">
                    Hoàn tất đặt hàng <i class="bi bi-arrow-right ms-2"></i>
                </button>

                <div class="mt-4 pt-3 border-top border-secondary text-center">
                    <div class="d-flex justify-content-center gap-3 opacity-50 small">
                        <span><i class="bi bi-shield-check"></i> Secure</span>
                        <span><i class="bi bi-patch-check"></i> Genuine</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}