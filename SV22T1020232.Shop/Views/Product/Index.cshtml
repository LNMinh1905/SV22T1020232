@model SV22T1020232.Models.Common.PagedResult<SV22T1020232.Models.Catalog.Product>
@{
    ViewData["Title"] = "Cửa hàng";
    var searchInput = ViewBag.SearchInput as SV22T1020232.Models.Catalog.ProductSearchInput;
    var categories = ViewBag.Categories as List<SV22T1020232.Models.Catalog.Category>;
}

<style>
    :root {
        --primary: #4F46E5;
        --primary-light: #EEF2FF;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --bg-body: #f8fafc;
    }

    /* Sidebar & Category Menu */
    .filter-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #edf2f7;
        padding: 24px;
        position: sticky;
        top: 20px;
    }

    .category-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .cat-item {
        display: flex;
        align-items: center;
        padding: 10px 12px;
        border-radius: 10px;
        text-decoration: none;
        color: var(--text-muted);
        font-size: 0.95rem;
        transition: all 0.2s;
        cursor: pointer;
    }

        .cat-item:hover {
            background: #f1f5f9;
            color: var(--primary);
        }

        .cat-item.active {
            background: var(--primary-light);
            color: var(--primary);
            font-weight: 600;
        }

        .cat-item i {
            font-size: 1.1rem;
            margin-right: 12px;
            opacity: 0.7;
        }

    /* Product Cards */
    .p-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .p-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.06);
        }

    .p-img-box {
        position: relative;
        padding-top: 100%;
        background: #fdfdfd;
        border-bottom: 1px solid #f8fafc;
    }

    .p-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 15px;
    }

    /* Headers & Sorting */
    .product-grid-header {
        background: #fff;
        border-radius: 16px;
        padding: 12px 20px;
        border: 1px solid #edf2f7;
        margin-bottom: 24px;
    }

    /* Price styling */
    .price-text {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--primary);
    }

    /* Custom Scrollbar for Sidebar if many categories */
    .category-list {
        max-height: 400px;
        overflow-y: auto;
        scrollbar-width: thin;
    }
</style>

<div class="container-fluid py-4" style="background: var(--bg-body); min-height: 100vh;">
    <div class="row">
        <aside class="col-lg-3 col-md-4 mb-4">
            <div class="filter-card shadow-sm">
                <div class="d-flex align-items-center mb-4">
                    <i class="bi bi-grid-fill text-primary me-2"></i>
                    <h6 class="fw-bold mb-0">DANH MỤC</h6>
                </div>

                <form id="frmSearch" method="get">
                    <input type="hidden" name="SearchValue" value="@searchInput?.SearchValue" />
                    <input type="hidden" name="Page" id="currentPage" value="@searchInput?.Page" />
                    <input type="hidden" name="CategoryID" id="hdnCategoryID" value="@searchInput?.CategoryID" />
                    <input type="hidden" name="SortBy" id="hdnSortBy" value="@searchInput?.SortBy" />

                    <div class="category-list mb-4">
                        <a href="javascript:;" onclick="updateCategory(0)"
                           class="cat-item @(searchInput?.CategoryID == 0 ? "active" : "")">
                            <i class="bi bi-collection"></i> <span>Tất cả sản phẩm</span>
                        </a>

                        @foreach (var cat in categories ?? new List<SV22T1020232.Models.Catalog.Category>())
                        {
                            <a href="javascript:;" onclick="updateCategory(@cat.CategoryID)"
                               class="cat-item @(searchInput?.CategoryID == cat.CategoryID ? "active" : "")">
                                <i class="bi bi-chevron-right small"></i> <span>@cat.CategoryName</span>
                            </a>
                        }
                    </div>

                    <hr class="text-faded my-4">

                    <div class="mb-4">
                        <label class="small fw-bold text-muted text-uppercase mb-3 d-block">Khoảng giá</label>
                        <div class="input-group input-group-sm mb-3">
                            <span class="input-group-text bg-light border-end-0">Từ</span>
                            <input type="number" name="MinPrice" class="form-control" value="@searchInput?.MinPrice" placeholder="0">
                        </div>
                        <div class="input-group input-group-sm mb-3">
                            <span class="input-group-text bg-light border-end-0">Đến</span>
                            <input type="number" name="MaxPrice" class="form-control" value="@searchInput?.MaxPrice" placeholder="999k+">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">
                        Áp dụng bộ lọc
                    </button>
                </form>
            </div>
        </aside>

        <main class="col-lg-9 col-md-8">
            <div class="product-grid-header d-flex justify-content-between align-items-center shadow-sm">
                <div class="text-muted">
                    Tìm thấy <span class="fw-bold text-dark">@Model.RowCount</span> sản phẩm
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="small text-muted d-none d-sm-block">Sắp xếp:</span>
                    <select class="form-select form-select-sm w-auto border-0 bg-light fw-medium" onchange="doSort(this.value)">
                        <option value="newest" selected="@(searchInput?.SortBy == "newest")">Mới nhất</option>
                        <option value="price_asc" selected="@(searchInput?.SortBy == "price_asc")">Giá: Thấp đến Cao</option>
                        <option value="price_desc" selected="@(searchInput?.SortBy == "price_desc")">Giá: Cao đến Thấp</option>
                    </select>
                </div>
            </div>

            <div class="row g-4">
                @foreach (var item in Model.DataItems)
                {
                    <div class="col-xl-3 col-lg-4 col-6">
                        <div class="p-card shadow-sm">
                            <a asp-action="Details" asp-route-id="@item.ProductID" class="text-decoration-none flex-grow-1">
                                <div class="p-img-box">
                                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                         class="p-img" onerror="this.src='/images/products/nophoto.png'">
                                </div>
                                <div class="p-3">
                                    <div class="text-dark fw-semibold text-truncate-2 mb-2" style="height: 2.6rem; font-size: 0.95rem; line-height: 1.3;">
                                        @item.ProductName
                                    </div>
                                    <div class="price-text">@item.Price.ToString("N0")₫</div>
                                    <div class="text-muted small mt-1">Đơn vị: @item.Unit</div>
                                </div>
                            </a>
                            <div class="p-3 pt-0">
                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    <input type="hidden" name="productId" value="@item.ProductID" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-sm btn-primary w-100 rounded-pill py-2">
                                        <i class="bi bi-bag-plus me-2"></i>Thêm vào giỏ
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.PageCount > 1)
            {
                <nav class="mt-5">
                    <ul class="pagination page-circle justify-content-center">
                        @foreach (var p in Model.GetDisplayPages(3))
                        {
                            <li class="page-item @(p.IsCurrent ? "active" : "") @(p.IsEllipsis ? "disabled" : "")">
                                <a class="page-link shadow-sm" href="#" onclick="doSearch(@p.Page); return false;">
                                    @(p.IsEllipsis ? "..." : p.Page.ToString())
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </main>
    </div>
</div>

@section Scripts {
    <script>
        function doSearch(page) { $('#currentPage').val(page); $('#frmSearch').submit(); }
        function doSort(val) { $('#hdnSortBy').val(val); doSearch(1); }
        function updateCategory(val) { $('#hdnCategoryID').val(val); doSearch(1); }
    </script>
}