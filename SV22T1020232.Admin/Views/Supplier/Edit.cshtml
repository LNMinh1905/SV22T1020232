@using SV22T1020232.Admin
@using SV22T1020232.Admin.Models
@using SV22T1020232.Models.Catalog
@using SV22T1020232.Models.Common
@using SV22T1020232.Models.DataDictionary
@using SV22T1020232.Models.HR
@using SV22T1020232.Models.Partner
@using SV22T1020232.Models.Sales
@using SV22T1020232.Models.Security
@model Supplier

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a asp-controller="Supplier"
       asp-action="Index"
       class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i>
                    Thông tin nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-action="Save">
                    <input type="hidden" asp-for="SupplierID" />

                    <div class="mb-3">
                        <label class="form-label">Tên nhà cung cấp</label>
                        <input asp-for="SupplierName" class="form-control" placeholder="Nhập tên nhà cung cấp" autofocus />
                        <span asp-validation-for="SupplierName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên giao dịch</label>
                        <input asp-for="ContactName" class="form-control" placeholder="Nhập tên giao dịch" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="Nhập email" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Nhập địa chỉ"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select class="form-select" asp-for="Province" asp-items="await SelectListHelper.Provinces()">
                        </select>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}