@model SV22T1020232.Models.Catalog.Product
@{
    ViewData["Title"] = Model.ProductName;
    var photos = ViewBag.Photos as List<SV22T1020232.Models.Catalog.ProductPhoto>;
    var attributes = ViewBag.Attributes as List<SV22T1020232.Models.Catalog.ProductAttribute>;
    var mainPhoto = string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo;
}

<style>
    /* Premium Page Styles */
    :root {
        --primary-indigo: #4F46E5;
        --border-color: #e2e8f0;
        --text-secondary: #64748b;
    }

    .app-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        overflow: hidden;
    }

    /* ── Gallery ── */
    .main-img-box {
        background: #f8fafc;
        border-radius: 12px;
        aspect-ratio: 1/1;
        overflow: hidden;
    }

        .main-img-box img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 15px;
        }

    .thumb-item {
        border-radius: 10px;
        border: 2px solid transparent;
        transition: 0.2s;
        cursor: pointer;
    }

        .thumb-item.active {
            border-color: var(--primary-indigo);
        }

    /* ── Product Info ── */
    .product-title {
        font-size: 1.7rem;
        font-weight: 800;
        color: #1e293b;
        line-height: 1.3;
    }

    .price-large {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--primary-indigo);
    }

    /* Input qty */
    .qty-group {
        background: #f1f5f9;
        border-radius: 10px;
        padding: 4px;
        display: inline-flex;
        align-items: center;
    }

    .btn-qty {
        width: 36px;
        height: 36px;
        border: none;
        background: #fff;
        border-radius: 8px;
        font-weight: bold;
    }

    .qty-input {
        width: 50px;
        border: none;
        background: transparent;
        text-align: center;
        font-weight: 600;
    }

    /* Buttons */
    .btn-add-cart {
        border: 2px solid var(--primary-indigo);
        color: var(--primary-indigo);
        font-weight: 700;
        border-radius: 12px;
    }

    .btn-buy-now {
        background: var(--primary-indigo);
        color: #fff;
        font-weight: 700;
        border-radius: 12px;
        box-shadow: 0 4px 12px rgba(79,70,229,0.2);
    }

        .btn-buy-now:hover {
            background: #3d34bd;
            color: #fff;
        }

    /* ── Description Panel ── */
    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 10px;
        margin-bottom: 15px;
    }

    .spec-row {
        border-bottom: 1px solid #f8fafc;
        padding: 12px 0;
        display: flex;
        justify-content: space-between;
    }
</style>

<div class="container py-4">
    <nav class="mb-4">
        <ol class="breadcrumb" style="font-size: 0.9rem;">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Cửa hàng</a></li>
            <li class="breadcrumb-item active fw-medium text-dark">Chi tiết</li>
        </ol>
    </nav>

    <div class="row g-4 mb-5">

        <div class="col-lg-6 col-12">
            <div class="app-card p-4 h-100">
                <div class="row g-4">
                    <div class="col-md-5">
                        <div class="main-img-box mb-3 shadow-sm border">
                            <img id="viewImg" src="/images/products/@mainPhoto"
                                 onerror="this.src='/images/products/nophoto.png'">
                        </div>
                        <div class="d-flex gap-2 overflow-auto pb-2" style="scrollbar-width: thin;">
                            <div class="thumb-item flex-shrink-0 active" style="width: 60px; height: 60px;" onclick="swapImg(this, '/images/products/@mainPhoto')">
                                <img src="/images/products/@mainPhoto" class="w-100 h-100 object-fit-cover rounded-2" onerror="this.src='/images/products/nophoto.png'">
                            </div>
                            @if (photos != null)
                            {
                                foreach (var p in photos)
                                {
                                    <div class="thumb-item flex-shrink-0" style="width: 60px; height: 60px;" onclick="swapImg(this, '/images/products/@p.Photo')">
                                        <img src="/images/products/@p.Photo" class="w-100 h-100 object-fit-cover rounded-2" onerror="this.src='/images/products/nophoto.png'">
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="col-md-7">
                        <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill small fw-bold mb-2">CHÍNH HÃNG</span>
                        <h1 class="product-title mb-3">@Model.ProductName</h1>

                        <div class="d-flex align-items-center gap-3 mb-4 border-bottom pb-3">
                            <div class="text-warning small"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i><span class="ms-1 text-dark fw-bold">4.9</span></div>
                            <span class="text-muted small">| Đã bán 1.2k+</span>
                        </div>

                        <div class="price-large mb-4">@Model.Price.ToString("N0") ₫</div>

                        <div class="mb-4">
                            <label class="d-block small fw-bold text-muted text-uppercase mb-2">Số lượng</label>
                            <div class="qty-group">
                                <button class="btn-qty" onclick="changeQty(-1)">-</button>
                                <input type="text" id="displayQty" value="1" class="qty-input" readonly>
                                <button class="btn-qty" onclick="changeQty(1)">+</button>
                            </div>
                            <span class="ms-3 text-muted small">(@Model.Unit)</span>
                        </div>

                        <form asp-controller="Cart" asp-action="AddToCart" method="post" id="mainCartForm">
                            <input type="hidden" name="productId" value="@Model.ProductID" />
                            <input type="hidden" name="quantity" id="realQty" value="1" />

                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-add-cart flex-grow-1 py-3">Thêm vào giỏ</button>
                                <button type="button" class="btn btn-buy-now flex-grow-1 py-3" onclick="handleBuyNow()">Mua ngay</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 col-12">
            <div class="app-card p-4 h-100">
                <div class="row g-4">
                    <div class="col-md-5 border-end pe-4">
                        <h6 class="section-title"><i class="bi bi-info-circle me-2"></i>Thông số kỹ thuật</h6>
                        <div class="spec-row">
                            <span class="text-muted small">Đơn vị tính</span>
                            <span class="fw-bold text-dark small">@Model.Unit</span>
                        </div>
                        @if (attributes != null)
                        {
                            foreach (var attr in attributes)
                            {
                                <div class="spec-row">
                                    <span class="text-muted small">@attr.AttributeName</span>
                                    <span class="fw-bold text-dark small text-truncate" title="@attr.AttributeValue" style="max-width: 150px;">@attr.AttributeValue</span>
                                </div>
                            }
                        }
                    </div>

                    <div class="col-md-7 ps-4">
                        <h6 class="section-title"><i class="bi bi-text-left me-2"></i>Mô tả sản phẩm</h6>
                        <div class="text-secondary lh-lg small" style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">
                            @(string.IsNullOrEmpty(Model.ProductDescription) ? "Thông tin đang được cập nhật..." : Model.ProductDescription)
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // Các hàm JavaScript xử lý gallery và số lượng giữ nguyên
        function swapImg(el, src) {
            document.getElementById('viewImg').src = src;
            $('.thumb-item').removeClass('active');
            $(el).addClass('active');
        }

        function changeQty(n) {
            let q = parseInt($('#displayQty').val()) + n;
            if (q < 1) q = 1;
            $('#displayQty').val(q);
            $('#realQty').val(q);
        }

        function handleBuyNow() {
            let form = $('#mainCartForm');
            $('<input>').attr({type: 'hidden', name: 'isImmediate', value: 'true'}).appendTo(form);
            form.submit();
        }
    </script>
}