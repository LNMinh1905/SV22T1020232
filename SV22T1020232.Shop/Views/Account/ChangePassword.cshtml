@model SV22T1020232.Shop.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Bảo mật tài khoản";
    var userData = SV22T1020232.Shop.WebUserExtensions.GetUserData(User);
    var photoSrc = string.IsNullOrEmpty(userData?.Photo) ? "/images/customers/nophoto.png" : $"/images/customers/{userData.Photo}";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        --surface-color: #ffffff;
    }

    .account-container {
        background: #f8fafc;
        border-radius: 30px;
        padding: 2rem;
    }

    /* Sidebar Styling */
    .premium-sidebar {
        background: var(--surface-color);
        border-radius: 24px;
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    .sidebar-header {
        background: var(--primary-gradient);
        padding: 2rem 1rem;
        color: white;
        text-align: center;
    }

    .nav-link-custom {
        padding: 12px 20px;
        margin: 8px 15px;
        border-radius: 12px;
        color: #64748b;
        font-weight: 600;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        text-decoration: none;
    }

        .nav-link-custom:hover {
            background: #f1f5f9;
            color: #6366f1;
        }

        .nav-link-custom.active {
            background: #f0f3ff;
            color: #6366f1;
        }

    /* Main Card Styling */
    .security-card {
        background: var(--surface-color);
        border-radius: 24px;
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 20px 40px -12px rgba(0,0,0,0.05);
    }

    .input-premium {
        border: 2px solid #f1f5f9;
        background: #f8fafc;
        border-radius: 14px !important;
        padding: 12px 16px;
        transition: 0.3s;
    }

        .input-premium:focus {
            border-color: #6366f1;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }

    .btn-update {
        background: var(--primary-gradient);
        border: none;
        padding: 14px 28px;
        border-radius: 14px;
        color: white;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
        }

    .security-icon-box {
        width: 45px;
        height: 45px;
        background: #f0fdf4;
        color: #16a34a;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
</style>

<div class="account-container mt-4 mb-5">
    <div class="row g-4">
        <div class="col-lg-3 col-md-4">
            <div class="premium-sidebar">
                <div class="sidebar-header">
                    <div class="position-relative d-inline-block mb-3">
                        <img src="@photoSrc" alt="Avatar" class="rounded-circle border border-4 border-white shadow"
                             style="width:85px;height:85px;object-fit:cover;">
                        <span class="position-absolute bottom-0 end-0 bg-success border border-2 border-white rounded-circle" style="width:18px;height:18px;"></span>
                    </div>
                    <h6 class="mb-0 fw-800 text-white">@userData?.CustomerName</h6>
                    <small class="opacity-75">@userData?.Email</small>
                </div>

                <div class="py-3">
                    <a class="nav-link-custom" asp-action="Profile">
                        <i class="bi bi-person-circle me-3"></i> Hồ sơ cá nhân
                    </a>
                    <a class="nav-link-custom active" asp-action="ChangePassword">
                        <i class="bi bi-shield-lock-fill me-3"></i> Bảo mật tài khoản
                    </a>
                    <a class="nav-link-custom" asp-controller="Order" asp-action="MyOrders">
                        <i class="bi bi-cart-check me-3"></i> Lịch sử mua hàng
                    </a>
                    <hr class="mx-4 opacity-5">
                    <a class="nav-link-custom text-danger" href="/Account/Logout">
                        <i class="bi bi-box-arrow-right me-3"></i> Đăng xuất
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="security-card p-4 p-md-5">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="security-icon-box">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <div>
                        <h4 class="fw-800 mb-1 text-dark">Đổi mật khẩu</h4>
                        <p class="text-muted small mb-0">Cập nhật mật khẩu định kỳ để bảo vệ quyền lợi của bạn.</p>
                    </div>
                </div>

                <div class="alert alert-info border-0 rounded-4 bg-primary bg-opacity-10 text-primary small mb-5 p-3 d-flex align-items-center">
                    <i class="bi bi-info-circle-fill fs-5 me-3"></i>
                    Mật khẩu mạnh bao gồm chữ cái, chữ số và ít nhất một ký tự đặc biệt.
                </div>

                <form asp-action="ChangePassword" method="post" id="changePwdForm" style="max-width: 550px;">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                    <div class="mb-4">
                        <label asp-for="CurrentPassword" class="form-label fw-700 text-dark small"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0 rounded-start-4"><i class="bi bi-key text-muted"></i></span>
                            <input asp-for="CurrentPassword" class="form-control input-premium" type="password"
                                   placeholder="Xác nhận mật khẩu cũ" id="currentPwd">
                            <button class="btn border-0 bg-light rounded-end-4 px-3" type="button" onclick="togglePwd('currentPwd', this)">
                                <i class="bi bi-eye text-muted"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger x-small mt-1"></span>
                    </div>

                    <div class="row g-3 mb-5">
                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="form-label fw-700 text-dark small"></label>
                            <div class="input-group">
                                <input asp-for="NewPassword" class="form-control input-premium" type="password"
                                       placeholder="Tối thiểu 8 ký tự" id="newPwd">
                                <button class="btn border-0 bg-light position-absolute end-0 h-100 px-3" style="z-index: 5;" type="button" onclick="togglePwd('newPwd', this)">
                                    <i class="bi bi-eye text-muted"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger x-small mt-1"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-700 text-dark small"></label>
                            <div class="input-group">
                                <input asp-for="ConfirmNewPassword" class="form-control input-premium" type="password"
                                       placeholder="Trùng khớp mật khẩu trên" id="confirmPwd">
                                <button class="btn border-0 bg-light position-absolute end-0 h-100 px-3" style="z-index: 5;" type="button" onclick="togglePwd('confirmPwd', this)">
                                    <i class="bi bi-eye text-muted"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger x-small mt-1"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <button type="submit" class="btn btn-update flex-grow-1">
                            LƯU THAY ĐỔI <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                        <a asp-action="Profile" class="btn btn-outline-secondary border-0 fw-600 rounded-4 px-4 py-3">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash text-primary';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye text-muted';
            }
        }
    </script>
}