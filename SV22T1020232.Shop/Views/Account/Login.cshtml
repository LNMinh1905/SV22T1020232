@model SV22T1020232.Shop.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    /* CSS NÂNG CẤP CHO TRANG LOGIN */
    .login-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
    }

    .auth-card {
        background: var(--surface);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        overflow: hidden;
        max-width: 900px;
        width: 100%;
    }

    .auth-banner {
        background: #0f172a; /* Cùng tông với Hero Banner */
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 3rem;
        color: white;
    }

        /* Hiệu ứng ánh sáng mờ giống Hero Banner */
        .auth-banner::before {
            content: "";
            position: absolute;
            top: -20%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: var(--primary);
            filter: blur(80px);
            border-radius: 50%;
            opacity: 0.2;
        }

    .form-control-modern {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 0.95rem;
        transition: all 0.2s;
        background-color: #f8fafc;
    }

        .form-control-modern:focus {
            background-color: #fff;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            outline: none;
        }

    .btn-login {
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

        .btn-login:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(99, 102, 241, 0.2);
        }

    .toggle-password {
        cursor: pointer;
        color: #94a3b8;
        transition: color 0.2s;
    }

        .toggle-password:hover {
            color: var(--primary);
        }

    .social-login-btn {
        border: 1px solid var(--border-color);
        background: white;
        border-radius: 12px;
        padding: 10px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 0.9rem;
        color: var(--text-dark);
        transition: all 0.2s;
    }

        .social-login-btn:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }
</style>

<div class="login-container">
    <div class="auth-card">
        <div class="row g-0">
            <div class="col-md-5 auth-banner d-none d-md-flex text-center text-md-start">
                <div class="position-relative" style="z-index: 2;">
                    <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none d-inline-block mb-5">
                        <span class="fs-4 fw-bold">LNM<span style="color: var(--primary);">.</span>SHOP</span>
                    </a>
                    <h2 class="display-6 fw-bold mb-3" style="line-height: 1.2;">Bắt đầu hành trình mua sắm.</h2>
                    <p class="text-muted-foreground mb-5" style="color: #94a3b8;">Đăng nhập để nhận ưu đãi cá nhân hóa và quản lý đơn hàng của bạn một cách dễ dàng.</p>

                    <div class="mt-auto">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle bg-success bg-opacity-10 p-2">
                                <i class="bi bi-shield-check text-success"></i>
                            </div>
                            <span class="small text-muted">Bảo mật tài khoản 100%</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7 p-4 p-lg-5 bg-white">
                <div class="mb-4">
                    <h3 class="fw-bold text-dark mb-1">Chào mừng trở lại!</h3>
                    <p class="text-muted small">Vui lòng nhập thông tin để truy cập tài khoản.</p>
                </div>

                <form asp-action="Login" method="post">
                    <input type="hidden" asp-for="ReturnUrl" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small rounded-3 py-2"></div>
                    }

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-semibold text-muted">Địa chỉ Email</label>
                        <input asp-for="Email" class="form-control-modern w-100" placeholder="name@example.com" autofocus />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label asp-for="Password" class="form-label small fw-semibold text-muted">Mật khẩu</label>
                            <a href="#" class="small text-decoration-none" style="color: var(--primary);">Quên mật khẩu?</a>
                        </div>
                        <div class="position-relative">
                            <input asp-for="Password" id="loginPassword" type="password"
                                   class="form-control-modern w-100" placeholder="••••••••" style="padding-right: 45px;" />
                            <span class="position-absolute end-0 top-50 translate-middle-y me-3 toggle-password"
                                  onclick="togglePassword('loginPassword', this)">
                                <i class="bi bi-eye"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMe" class="form-check-input" id="rememberCheck" />
                        <label class="form-check-label small text-muted user-select-none" for="rememberCheck">
                            Duy trì đăng nhập cho lần sau
                        </label>
                    </div>

                    <button type="submit" class="btn-login w-100 mb-4">
                        Đăng nhập ngay
                    </button>

                    <div class="position-relative text-center mb-4">
                        <hr class="text-muted opacity-25">
                        <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 small text-muted">Hoặc đăng nhập với</span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <button type="button" class="social-login-btn">
                                <img src="https://www.svgrepo.com/show/355037/google.svg" width="18" alt="Google"> Google
                            </button>
                        </div>
                        <div class="col-6">
                            <button type="button" class="social-login-btn">
                                <i class="bi bi-facebook text-primary"></i> Facebook
                            </button>
                        </div>
                    </div>

                    <div class="text-center">
                        <span class="text-muted small">Bạn chưa có tài khoản?</span>
                        <a asp-action="Register" class="small fw-bold text-decoration-none ms-1" style="color: var(--primary);">Đăng ký miễn phí</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}