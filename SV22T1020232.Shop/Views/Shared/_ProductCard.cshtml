@model Product

<style>
    .premium-product-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
        overflow: hidden;
        border: 1px solid #f8fafc;
    }

        .premium-product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.08);
            border-color: #f1f5f9;
        }

    .product-img-wrapper {
        position: relative;
        padding-top: 100%; /* Giữ khung ảnh vuông 1:1 */
        background-color: #f8fafc; /* Nền xám nhạt giúp sản phẩm nổi bật */
        overflow: hidden;
    }

    .product-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        padding: 1rem; /* Tạo khoảng thở cho ảnh */
        transition: transform 0.5s ease;
    }

    .premium-product-card:hover .product-img {
        transform: scale(1.08); /* Hiệu ứng zoom ảnh mượt mà khi hover */
    }

    .product-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: #1e293b;
        line-height: 1.4;
        height: 2.8em;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-decoration: none;
        transition: color 0.2s ease;
    }

        .product-title:hover {
            color: var(--primary, #4F46E5);
        }

    .btn-view-detail {
        background: #f1f5f9;
        color: #475569;
        border: none;
        border-radius: 10px;
        font-weight: 500;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    /* Đổi màu nút khi hover vào Card */
    .premium-product-card:hover .btn-view-detail {
        background: var(--primary, #4F46E5);
        color: #ffffff;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25);
    }
</style>

<div class="card h-100 premium-product-card">
    <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.ProductID" class="text-decoration-none">
        <div class="product-img-wrapper">
            @{
                var imgSrc = string.IsNullOrEmpty(Model.Photo) ? "/images/products/nophoto.png" : $"/images/products/{Model.Photo}";
            }
            <img src="@imgSrc" class="product-img" alt="@Model.ProductName" onerror="this.src='/images/products/nophoto.png'">

            @* <span class="position-absolute top-0 start-0 m-3 badge bg-white text-primary shadow-sm rounded-pill px-2 py-1 border" style="font-size: 0.7rem; z-index: 2;">Mới</span> *@
        </div>
    </a>

    <div class="card-body p-3 p-md-4 d-flex flex-column">
        <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.ProductID" class="product-title mb-3">
            @Model.ProductName
        </a>

        <div class="mt-auto">
            <div class="d-flex justify-content-between align-items-end mb-3">
                <div class="text-muted small">ĐVT: @Model.Unit</div>
                <div class="fw-bold fs-5" style="color: var(--primary, #4F46E5);">
                    @Model.Price.ToString("N0") <span class="small text-muted" style="font-size: 0.85rem;">₫</span>
                </div>
            </div>

            <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.ProductID"
               class="btn btn-view-detail w-100 py-2 d-flex justify-content-center align-items-center gap-2">
                <i class="bi bi-eye"></i> Xem chi tiết
            </a>
        </div>
    </div>
</div>