@model OrderViewInfo
@{
    Layout = null;
    var shipList = ViewBag.ShipperList as SelectList;
}
<div class="modal-header text-bg-info">
    <strong class="modal-title">
        Chọn người giao hàng — Đơn #@Model.OrderID
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form id="formOrderShipping" method="post" action="@Url.Action("Shipping", "Order", new { id = Model.OrderID })" onsubmit="return handleOrderShipping(event, this);">
    <div class="modal-body">
        <div class="row">
            <div class="col-12">
                <label class="form-label">Người giao hàng</label>
                <select class="form-select" name="shipperID" required>
                    <option value="0">-- Chọn người giao hàng ---</option>
                    @if (shipList != null)
                    {
                        foreach (var opt in shipList)
                        {
                            <option value="@opt.Value">@opt.Text</option>
                        }
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-bicycle"></i> Giao hàng
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>
<script>
    function handleOrderShipping(event, form) {
        event.preventDefault();

        const formData = new FormData(form);

        fetch(form.action, {
            method: 'POST',
            body: formData
        })
        .then(response => {
            if (!response.ok) {
                throw new Error('Lỗi khi gọi API');
            }
            return response.json();
        })
        .then(result => {
            if (result.Code === 0) {
                alert(result.Message);
            } else {
                const modalElement = document.getElementById('dialogModal');
                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                if (modalInstance) {
                    modalInstance.hide();
                }
                alert(result.Message || 'Chuyển giao hàng thành công!');
                window.location.reload();
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Không gửi được yêu cầu');
        });

        return false;
    }
</script>
